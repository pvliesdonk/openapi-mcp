# OpenAPI MCP environment variables (copy to .env and fill in).

# --- Server ---
# OAPI_SERVER_NAME=openapi-mcp   # rename this instance (default: openapi-mcp)
# OAPI_INSTRUCTIONS=                     # replace the default MCP instructions text
# OAPI_TRANSPORT=stdio   # stdio | http | sse
# OAPI_HOST=127.0.0.1
# OAPI_PORT=8000
# OAPI_HTTP_PATH=/mcp
# OAPI_BASE_URL=https://mcp.example.com

# --- Authentication (pick one flavor) ---
# OAPI_BEARER_TOKEN=<secret>

# OAPI_BEARER_TOKENS_FILE=/etc/openapi-mcp/tokens.toml   # mapped per-token subjects (overrides BEARER_TOKEN)

# OAPI_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
# OAPI_OIDC_CLIENT_ID=<client-id>
# OAPI_OIDC_CLIENT_SECRET=<client-secret>
# OAPI_OIDC_AUDIENCE=
# OAPI_OIDC_REQUIRED_SCOPES=openid
# OAPI_OIDC_JWT_SIGNING_KEY=<hex-string>

# --- Remote debugger (development only — image must be built with --build-arg DEBUG=true) ---
# OAPI_DEBUG_PORT=5678
# OAPI_DEBUG_WAIT=false   # set true to block startup until the IDE attaches

# --- Domain (populate from your ProjectConfig) ---
