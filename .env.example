# OpenAPI MCP environment variables (copy to .env and fill in).

# --- Server ---
# OAPI_SERVER_NAME=openapi-mcp   # rename this instance (default: openapi-mcp)
# OAPI_INSTRUCTIONS=                     # replace the default MCP instructions text
# OAPI_TRANSPORT=stdio   # stdio | http | sse
# OAPI_HOST=127.0.0.1
# OAPI_PORT=8000
# OAPI_HTTP_PATH=/mcp
# OAPI_BASE_URL=https://mcp.example.com

# --- Authentication (pick one flavor) ---
# OAPI_BEARER_TOKEN=<secret>

# OAPI_BEARER_TOKENS_FILE=/etc/openapi-mcp/tokens.toml   # mapped per-token subjects (overrides BEARER_TOKEN)

# OAPI_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
# OAPI_OIDC_CLIENT_ID=<client-id>
# OAPI_OIDC_CLIENT_SECRET=<client-secret>
# OAPI_OIDC_AUDIENCE=
# OAPI_OIDC_REQUIRED_SCOPES=openid
# OAPI_OIDC_JWT_SIGNING_KEY=<hex-string>

# --- Remote debugger (development only — image must be built with --build-arg DEBUG=true) ---
# OAPI_DEBUG_PORT=5678
# OAPI_DEBUG_WAIT=false   # set true to block startup until the IDE attaches

# --- Domain: OpenAPI wrapper ---
# Exactly one of SPEC_URL / SPEC_PATH is required.
# OAPI_SPEC_URL=https://api.example.com/openapi.json   # HTTPS URL of the spec, fetched at boot
# OAPI_SPEC_PATH=/etc/openapi-mcp/openapi.json         # mounted spec file (air-gapped / configmap)
# OAPI_API_BASE_URL=https://api.example.com            # override upstream base (default: spec servers[0].url)
# OAPI_HTTP_TIMEOUT=30                                 # upstream request timeout, seconds (default 30)
#
# Upstream credentials — one var per security scheme referenced by the spec,
# named OAPI_SECURITY_<SCHEMEKEY-UPPERCASED>. Value form depends on scheme type:
#   apiKey (header/query) -> raw key
#   http bearer           -> raw token
#   http basic            -> user:pass  (single string, split on the first colon)
# OAPI_SECURITY_APIKEYAUTH=<raw-key>
# OAPI_SECURITY_BEARERAUTH=<raw-token>
# OAPI_SECURITY_BASICAUTH=user:pass
#
# oauth2 / openIdConnect / mutualTLS upstream schemes are out of scope — use a
# purpose-built sibling scaffolded from fastmcp-server-template.
