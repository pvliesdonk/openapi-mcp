# OIDC authentication example
# See docs/guides/authentication.md for setup instructions

OAPI_BASE_URL=https://mcp.example.com
OAPI_OIDC_CONFIG_URL=https://auth.example.com/.well-known/openid-configuration
OAPI_OIDC_CLIENT_ID=mcp-client
OAPI_OIDC_CLIENT_SECRET=your-client-secret
OAPI_OIDC_JWT_SIGNING_KEY=your-signing-key   # openssl rand -hex 32
OAPI_READ_ONLY=false
