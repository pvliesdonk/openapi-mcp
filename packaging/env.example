# OpenAPI MCP environment configuration
#
# Installed to /etc/openapi-mcp/env.example.
# Copy to /etc/openapi-mcp/env and edit for your deployment; the
# systemd unit (/usr/lib/systemd/system/openapi-mcp.service) sources
# /etc/openapi-mcp/env via EnvironmentFile=.

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR
FASTMCP_LOG_LEVEL=INFO
# Set to false for plain/structured JSON output instead of Rich formatting.
FASTMCP_ENABLE_RICH_LOGGING=true

# --- Domain configuration ---
# All domain env vars use the OAPI_ prefix.
# See the README and `openapi-mcp serve --help` for the full list.
#
# Example:
# OAPI_EXAMPLE_VAR=value
